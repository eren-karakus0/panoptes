# ── Database (Neon PostgreSQL) ──────────────────────────────────
# Pooled connection — used by the application at runtime
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/panoptes?sslmode=require"
# Direct connection — used only for Prisma migrations
DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/panoptes?sslmode=require"

# ── Republic Chain ─────────────────────────────────────────────
REPUBLIC_RPC_URL="https://rpc.republicai.io"
REPUBLIC_REST_URL="https://rest.republicai.io"

# ── Cron Security ──────────────────────────────────────────────
# Bearer token for cron job authentication (GitHub Actions → API)
# Generate with: openssl rand -hex 32
CRON_SECRET="change-me-to-a-strong-random-string"

# ── Cron Control ───────────────────────────────────────────────
# Set to "true" in GitHub Actions to enable scheduled cron jobs
CRONS_ENABLED="false"

# ── Application ────────────────────────────────────────────────
# Public URL (used for CORS, sitemap, OG images)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
