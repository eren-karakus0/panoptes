# Database (Neon PostgreSQL)
# Pooled connection (application queries)
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.eu-central-1.aws.neon.tech/panoptes?sslmode=require"
# Direct connection (migrations)
DIRECT_URL="postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/panoptes?sslmode=require"

# Republic Chain
REPUBLIC_RPC_URL="https://rpc.republicai.io"
REPUBLIC_REST_URL="https://rest.republicai.io"

# Cron Security (GitHub Actions -> Vercel API)
CRON_SECRET="change-me-to-a-strong-random-string"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# GitHub Actions Cron (set as GitHub secret, not needed locally)
# APP_URL="https://panoptes.vercel.app"
